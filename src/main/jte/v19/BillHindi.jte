@param com.mppkvvcl.jteone.dtos.templates.BillTemplate billTemplate

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <title>WZ Electricity Bill</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <style>
        @page { size: A4; margin: 3mm; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body{
          font-family: "Noto Sans Devanagari","Lohit Devanagari","Mangal","Nirmala UI","DejaVu Sans", Arial, Helvetica, sans-serif;
          color:#0f172a;
          background:#ffffff;
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }

        .page{
          width: 200mm;
          min-height: 287mm;
          margin: 0 auto;
          position: relative;
          padding: 0;
          page-break-after: always;
          padding-bottom: 12mm;
        }
        .page:last-child{ page-break-after: auto; }

        :root{
          --blue:#1f6fb2;
          --blue2:#0f4f87;
          --line:#b9c7d6;
          --soft:#f3f7fb;
          --soft2:#eef4fa;
          --ink:#0f172a;
          --muted:#334155;
          --warn:#e74c3c;
        }

        /* HEADER (UNCHANGED) */
        .header-top{
          text-align:center;
          padding: 6px 0 6px;
          border: 2px solid var(--blue);
          margin-bottom: 8px;
        }
        .header-left{
          display: table;
          width: 100%;
          border-collapse: collapse;
        }
        .header-cell{
          display: table-cell;
          vertical-align: middle;
        }
        .header-cell.left,
        .header-cell.right{
          width: 60px;
          text-align:center;
        }
        .logo-circle{
          width: 54px;
          height: 54px;
          border: 1px solid var(--line);
          border-radius: 50%;
          display:inline-block;
          overflow:hidden;
          background:#fff;
        }
        .logo-circle img{
          width: 54px;
          height: 54px;
          object-fit: contain;
          display:block;
        }
        .company-info{ padding: 0 6px; }
        .company-title{
          font-size: 14px;
          font-weight: 900;
          text-transform: uppercase;
          color:#0b2b74;
          line-height: 1.2;
        }
        .company-subtitle{
          font-size: 11px;
          color:#1f2937;
          font-weight: 700;
          line-height: 1.2;
          margin-top: 1px;
        }
        .tagline{
          font-size: 10px;
          color:#475569;
          margin-top: 2px;
          line-height: 1.2;
        }
        .tagline a{ color:#0b2b74; text-decoration:none; font-weight:800; }

        .box{ border: 1px solid var(--line); background:#fff; }
        .box.soft{ background: var(--soft); }
        .pad-5{ padding: 4px; }
        .pad-6{ padding: 6px; }
        .pad-8{ padding: 8px; }
        .mt-6{ margin-top: 6px; }
        .mt-8{ margin-top: 8px; }
        .mt-10{ margin-top: 10px; }
        .center{ text-align:center; }
        .right{ text-align:right; }
        .small{ font-size: 9px; color:#475569; }
        .muted{ color:#475569; }

        .band-title{
          background: var(--blue);
          color:#fff;
          font-weight: 800;
          text-transform: uppercase;
          font-size: 11px;
          padding: 3px 4px;
          letter-spacing: .3px;
          border: 1px solid var(--blue2);
          margin-top: 1px;
        }

        table{ width: 100%;
          border-collapse: collapse !important;
         border-spacing: 0 !important;
     }
        th, td{
          border: 1px solid var(--line);
          padding: 6px 6px;
          font-size: 10.5px;
          vertical-align: top;
           border-collapse: collapse !important;
        }
        th{
          background: var(--soft2);
          font-weight: 900;
          color:#0f2f52;
        }
        .no-border td, .no-border th{ border: none; }
        .tight td, .tight th{ padding: 5px; }

        /* Page-1 top banner */
        .p1-top{
          display: table;
          width: 100%;
          border-collapse: collapse;
          margin-top: 6px;
        }
        .p1-top .left{
          display: table-cell;
          width: 60mm;
          background: var(--blue);
          color:#fff;
          border: 2px solid var(--blue);
          vertical-align: middle;
          text-align:center;
          padding: 10px 8px;
          font-size: 22px;
          font-weight: 900;
          line-height: 1.05;
        }
        .p1-top .right{
          display: table-cell;
          border: 2px solid var(--blue);
          padding: 8px;
          vertical-align: top;
        }
        .kv{
          display: table;
          width:100%;
          border-collapse: collapse;
          margin-top: 2px;
        }
        .kv .r{ display: table-row; }
        .kv .k, .kv .v{
          display: table-cell;
          font-size: 11px;
          padding: 1px 0;
          vertical-align: top;
        }
        .kv .k{ width: 28mm; font-weight: 900; color:#0f2f52; }
        .kv .v{ color:#0f172a; }

        /* Mid strip */
        .info-strip td{
          border: none;
          /* padding: 6px 8px; */
          font-size: 10.5px;
        }
        .info-strip .lbl{
          font-weight: 900;
          text-transform: uppercase;
          color:#0f2f52;
          font-size: 10px;
          display:block;
          /* margin-bottom: 2px; */
        }
        .info-strip .val{ font-weight: 600; }

        /* Payment area */
        .pay-grid{
          display: table;
          width:100%;
          border-collapse: collapse;
        }
        .pay-grid .c1, .pay-grid .c2{
          display: table-cell;
          vertical-align: top;
        }
        .pay-grid .c1{ width: 58mm; }
        .qr-box{
          border: 1px solid var(--line);
          padding: 6px;
          background:#fff;
        }
        .qr-row{
          display: table;
          width:100%;
          border-collapse: collapse;
        }
        .qr-row .qr{
          display: table-cell;
          width: 28mm;
          text-align:center;
          vertical-align: middle;
        }
        .qr-row img{ width: 90px; height: 90px; object-fit: cover; border: 1px solid var(--line); }
        .qr-row .amt{
          display: table-cell;
          padding-left: 8px;
          vertical-align: top;
        }
        .big-rupee{ font-size: 18px; font-weight: 950; margin-top: 6px; }
        .due-pill{
          margin-top: 6px;
          background: var(--warn);
          color:#fff;
          font-weight: 900;
          font-size: 11px;
          padding: 5px 6px;
          text-align:center;
        }
        .pay-options{
          margin-top: 6px;
          border: 1px solid var(--line);
          background: var(--soft);
          padding: 6px;
          font-weight: 900;
          color:#0f2f52;
          text-transform: uppercase;
          font-size: 10px;
        }

        /* Charts */
        .chart-wrap{
          border: 1px solid var(--line);
          background:#fff;
          padding: 6px;
        }
        .chart{ width: 100% !important; height: 140px !important; }
        .chart-lg{ height: 165px !important; }
        .chart-md{ height: 150px !important; }
        .chart-sm{ height: 125px !important; }

        .two-col{
          display: table;
          width:100%;
          border-collapse: collapse;
        }
        .two-col .l, .two-col .r{
          display: table-cell;
          vertical-align: top;
        }
        .two-col .l{ width: 95mm; padding-right: 6px; }
        .two-col .r{ width: 95mm; padding-left: 6px; }

        .poster{
          border: 1px solid var(--line);
          background:#fff;
          height: 80px;
          overflow:hidden;
          text-align:center;
        }
        .poster img{
          width: 100%;
          height: 90px;
          object-fit: cover;
          display:block;
        }

        .meter-strip td{
          font-size: 10px;
          font-weight: 800;
          text-align:center;
        }
        .meter-strip th{
          font-size: 10px;
          text-transform: uppercase;
          letter-spacing: .2px;
        }

        /* Footer (page-2 style) */
        .footer{
          position: absolute;
          left: 0;
          right: 0;
          bottom: 0;
          padding-top: 0.5px;
        }
        .footer-line{
          border-top: 1px dashed #7aa7cf;
          margin-top: 10px;
        }
        .barcode{
          margin-top: 6px;
          text-align:center;
          font-size: 10px;
          letter-spacing: 2px;
          color:#111827;
          font-weight: 900;
        }
        .footer-ids{
          margin-top: 6px;
          font-size: 10px;
          font-weight: 900;
          color:#0f2f52;
        }
        .footer-ids table td{ border:none; padding: 2px 4px; }

        @media print{
          body{ background:#fff; }
          a{ color:#0b2b74; text-decoration:none; }
        }
         .page-header {
            margin-bottom: 10px;
            overflow: hidden;
        }
        .page-header-bill-no {
            font-size: 12px;
            font-weight: bolder;
            text-transform: uppercase;
            float: left;
        }
        .page-header-month {
            font-size: 12px;
            font-weight: 600;
            float: right;
        }
        .page-footer{
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;                 /* sits at bottom INSIDE the page box */
      height: 10mm;
      border-top: 1px solid var(--line);
      background: #fff;
      display: table;
      width: 100%;
      table-layout: fixed;
      /* padding: 2mm 2mm 0; */
      font-size: 9px;
      font-weight: 900;
      color: var(--ink);
    }

    .page-footer-left,
    .page-footer-center,
    .page-footer-right{
      display: table-cell;
      vertical-align: middle;
      width: 33.33%;
    }

    .page-footer-left{ text-align: left; }
    .page-footer-center{ text-align: center; }
    .page-footer-right{ text-align: right; }
    </style>
</head>

<body>
<!-- PAGE 1 -->
<div class="page">
    <!-- HEADER -->
    <div class="header-top">
        <div class="header-left">
            <div class="header-cell left">
                <img src="${billTemplate.getCompanyInformation().getLogoBase64()}" alt=""
                     style="width:60px; height:60px;">
            </div>
            <div class="header-cell">
                <div class="company-info">
                    <div class="company-title">
                        <strong>${billTemplate.getCompanyInformation().getFullNameHindi()}</strong>
                    </div>
                    <div class="company-subtitle">${billTemplate.getCompanyInformation().getAddressHindi()}</div>
                    <div class="company-subtitle">(मध्य प्रदेश शासन के पूर्ण स्वामित्व वाली)</div>
                    <div class="tagline">
                        <a href="${billTemplate.getCompanyInformation().getWebsite()}"
                           target="_blank">वेबसाइट: ${billTemplate.getCompanyInformation().getWebsite()}</a> |
                        <a href="tel:${billTemplate.getCompanyInformation().getCustomerCareNumber()}">कॉल
                            सेंटर: ${billTemplate.getCompanyInformation().getCustomerCareNumber()}</a>
                    </div>
                    <div class="tagline">
                        जीएसटी नं: <strong>${billTemplate.getCompanyInformation().getGstNo()}</strong> |
                        सीआईएन नं: <strong>${billTemplate.getCompanyInformation().getCiNo()}</strong>
                    </div>
                </div>
            </div>

            <div class="header-cell right">
                <img src="${billTemplate.getCompanyInformation().getAlternateLogoBase64()}" alt=""
                     style="width:60px; height:60px;">
            </div>
        </div>
    </div>

    <div class="page-header">
        <div class="page-header-bill-no">
            बिजली बिल नं: ${billTemplate.getBillSummary().getBillNo()}
        </div>
        <div class="page-header-month">
            बिल माह: ${billTemplate.getBillSummary().getBillMonth()}
        </div>
    </div>
    <!-- Top Banner + Consumer -->
    <div class="box soft mt-8 pad-6">

        <table class="info-strip" style="width:100%;">
            <!-- Row 1 -->
            <tr>
                <td style="width:25%;">
                    <span class="lbl">उपभोक्ता नंबर</span>
                    <span class="val">N${billTemplate.getConsumerInformation().getConsumerNo()}</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">मोबाइल</span>
                    <span class="val">${billTemplate.getConsumerInformation().getMobileNo()}</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">ईमेल</span>
                    <span class="val">${billTemplate.getConsumerInformation().getEmailId()}</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">कर्मचारी नंबर</span>
                    <span class="val">${billTemplate.getConsumerInformation().getEmployeeNo()}</span>
                </td>
            </tr>
            <!-- Name & Address -->
            <tr>
                <td colspan="2">
                    <span class="lbl">उपभोक्ता नाम</span>
                    <span class="val">${billTemplate.getConsumerInformation().getConsumerNameHindi()}</span>
                </td>
                <td colspan="2">
                    <span class="lbl">पता</span>
                    <span class="val">${billTemplate.getConsumerInformation().getAddressHindi()}</span>
                </td>
            </tr>
        </table>
    </div>


    <!-- Mid info strip -->
    <div class="box soft mt-1">
        <table class="info-strip" style="width:100%;">
            <tr>
                <td style="width:25%;">
                    <span class="lbl">डिवीजन</span>
                    <span class="val">${billTemplate.getConnectionInformation().getDivisionName()}</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">जोन / डीसी</span>
                    <span class="val">कलानी नगर जोन</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">ग्रुप नंबर</span>
                    <span class="val">KNW47</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">आरडी नंबर</span>
                    <span class="val">12</span>
                </td>
            </tr>
            <tr>

                <td style="width:25%;">
                    <span class="lbl">फीडर कोड</span>
                    <span class="val">3465201125414</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">डीटीआर कोड</span>
                    <span class="val">3465201125414</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">पोल नंबर</span>
                    <span class="val">125441514</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">उपयोग</span>
                    <span class="val">घरेलू</span>
                </td>
            </tr>
            <tr>
                <td style="width:25%;">
                    <span class="lbl">परिसर प्रकार</span>
                    <span class="val">शहरी</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">टैरिफ श्रेणी</span>
                    <span class="val">LV1 (LV1.2)</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">कनेक्शन तिथि</span>
                    <span class="val">23-06-2017</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">फेज</span>
                    <span class="val">सिंगल</span>
                </td>
            </tr>
            <tr>
                <td style="width:25%;">
                    <span class="lbl">स्वीकृत लोड (kW)</span>
                    <span class="val">1.0</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">कॉन्ट्रैक्ट डिमांड</span>
                    <span class="val">1.0 kW</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">नेट मीटर</span>
                    <span class="val">हाँ</span>
                </td>
                <td style="width:25%;">
                    <span class="lbl">प्रीपेड</span>
                    <span class="val">हाँ</span>
                </td>
            </tr>
        </table>
    </div>
    <table class="tight" style="margin-bottom: -8px;">
        <tr>
            <th style="width:20%;">अंतिम तिथि</th>
            <th style="width:20%;">खपत</th>
            <th style="width:20%;">चालू माह बिल</th>
            <th style="width:20%;">अंतिम तिथि बाद भुगतान</th>
            <th style="width:20%;">पिछला बकाया</th>
        </tr>
        <tr>
            <td class="center" style="font-size: 15px;"><b>10-08-2025</b></td>
            <td class="center" style="font-size: 15px;"><b>808.98</b></td>
            <td class="center" style="font-size: 15px;"><b>₹ 1,200.00</b></td>
            <td class="center" style="font-size: 15px;"><b>₹ 2,190.00</b></td>
            <td class="center" style="font-size: 15px;"><b>₹ 1,618.00</b></td>
        </tr>
    </table>
    <!-- Payment + summary row -->
    <div class="mt-8 pay-grid">
        <div class="c1" style="text-align: center;">
            <div class="box"><strong><span style="font-size:11px;">Scan to Pay <b>₹ 2,163.00</b></span></strong>
                <div>
                    <img src="qr_codeimage.png" style="height: 54px; width: 54px;" alt="Swachh Bharat">
                    <!-- <img style="height: 36px; width: 36px;" src="data:image/jpeg;base64," alt="QR Code" style="width:80px; height:80px;"> -->
                </div>
                <div></div>
            </div>
        </div>

        <!-- Right: Bill month summary -->
        <div class="c2">
            <div class="box">
                <table class="info-strip" style="width:100%;">
                    <!-- Row 1 -->
                    <tr>
                        <td style="width:25%;">
                            <span class="lbl">बिल दिनांक</span>
                            <span class="val">01-11-2025</span>
                        </td>
                        <td style="width:25%;">
                            <span class="lbl">बिल प्रकार</span>
                            <span class="val">वास्तविक बिल</span>
                        </td>
                        <td style="width:25%;">
                            <span class="lbl">मीटर रीडर</span>
                            <span class="val">श्याम कुमार</span>
                        </td>
                        <td style="width:25%;">
                            <span class="lbl">बिल आधार</span>
                            <span class="val">संशोधित बिल</span>
                        </td>
                    </tr>

                    <!-- Row 2 -->
                    <tr>
                        <td>
                            <span class="lbl">दैनिक औसत (राशि)</span>
                            <span class="val">808.98</span>
                        </td>
                        <td>
                            <span class="lbl">दैनिक औसत यूनिट</span>
                            <span class="val">12</span>
                        </td>
                        <td>
                            <span class="lbl">सुरक्षा जमा (S.D.)</span>
                            <span class="val">500.00</span>
                        </td>
                        <td>
                            <span class="lbl">S.D. लंबित</span>
                            <span class="val">0.00</span>
                        </td>
                    </tr>
                </table>

            </div>
        </div>

    </div>
    <table class="small">
        <tr>
            <td style="padding-bottom: -15px;"><b>सहायक / कनिष्ठ अभियंता:</b><br>
                <b>सगम नगर जोन</b></td>
            <td><b>श्री राहुल सिंह <br> (1800-233-1912) </b></td>
            <td rowspan="2" style="text-align: center; padding: -15px;">
                <strong><span style="font-size:11px;">WhatsApp ChatBot / Call Centre: 1912</span></strong>
                <div>
                    <img src="qr_codeimage.png" style="height: 54px; width: 54px;" alt="Swachh Bharat">
                    <!-- <img style="height: 45px; width: 45px;" src="data:image/jpeg;base64," alt="WhatsApp QR" style="width:80px; height:80px;"> -->
                </div>
            </td>
        </tr>
        <tr>
            <td><b>कार्यपालन अभियंता:</b><br>
                <b>इंदौर ईस्ट डिवीजन</b></td>
            <td><b>श्री श्याम सिंह राठौर <br>(1800-233-1912) </b></td>
        </tr>
    </table>
    <!-- Consumption Trend -->
    <div class="mt-1">
        <div class="band-title">खपत प्रवृत्ति (यूनिट में)</div>
        <div class="chart-wrap">
            <img style="width: 100%; height: 140px;"
                 src="data:image/png;base64,"
                 alt="Consumption Trend">
        </div>
    </div>

    <!-- Major components + awareness image -->
    <div class="mt-1">
        <div class="band-title">विज्ञापन / जागरूकता हेतु स्थान</div>
        <div class="poster" style="height: 130px;">
            <img src="advertisement_img.jpg" style="height: 100%; width: 100%;" alt="Swachh Bharat">
        </div>
    </div>
    <div class="mt-1">
        <div class="band-title">संदेश / टीप:</div>
        <div class="soft pad-5" style="font-size:9px;">
            आपका कनेक्शन <b>22-10-2025</b> को <b>OTS 2025 समाधान योजना</b> हेतु पंजीकृत किया गया है।
            <b>₹ 500.00</b> की <b>6 किस्तें</b> बिल माह <b>NOV-2025</b> से <b>APR-2026</b> तक निर्धारित हैं।
            योजना लाभ हेतु कृपया चालू बिल के साथ किस्त का भुगतान करें।
        </div>
        <div class="soft pad-5" style="font-size:9px;">
            आपका कनेक्शन <b>22-10-2025</b> को <b>OTS 2025 समाधान योजना</b> हेतु पंजीकृत किया गया है।
            <b>₹ 500.00</b> की <b>6 किस्तें</b> बिल माह <b>NOV-2025</b> से <b>APR-2026</b> तक निर्धारित हैं।
            योजना लाभ हेतु कृपया चालू बिल के साथ किस्त का भुगतान करें।
        </div>
        <div class="soft pad-5" style="font-size:9px;">
            आपका कनेक्शन <b>22-10-2025</b> को <b>OTS 2025 समाधान योजना</b> हेतु पंजीकृत किया गया है।
