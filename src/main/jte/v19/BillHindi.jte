<!-- Charts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<script>
    Chart.register(ChartDataLabels);

    document.addEventListener('DOMContentLoaded', function(){

      // Page-1 Consumption Trend (from provided data)
      const p1c = document.getElementById('p1ConsumptionTrend');
      if(p1c){
        new Chart(p1c, {
          type:'bar',
          data:{
            labels:['अप्रै','जून','अग','अक्टू','दिसं','फर'],
            datasets:[
              { label:'पिछला वर्ष', data:[31,35,43,58,33,32], backgroundColor:'rgba(245,158,11,0.75)', borderRadius:6 },
              { label:'चालू वर्ष',  data:[46,34,35,38,30,26], backgroundColor:'rgba(31,111,178,0.85)', borderRadius:6 }
            ]
          },
          options:{
            responsive:true,
            maintainAspectRatio:false,
            plugins:{
              legend:{ position:'top' },
              datalabels:{ anchor:'end', align:'end', offset:-2, font:{ size:9, weight:'bold' } }
            },
            scales:{
              x:{ grid:{ display:false }, ticks:{ font:{ size:9 } } },
              y:{ beginAtZero:true, ticks:{ font:{ size:9 } } }
            }
          }
        });
      }

      // Page-1 Major components (from provided data)
      const p1m = document.getElementById('p1MajorComponents');
      if(p1m){
        new Chart(p1m, {
          type:'doughnut',
          data:{
            labels:['ऊर्जा','स्थिर','विद्युत ड्यूटी','FPPPA','अन्य/शुल्क'],
            datasets:[{
              data:[658.18,106.00,62.00,17.19,186.00],
              backgroundColor:[
                'rgba(245,158,11,0.80)',
                'rgba(31,111,178,0.85)',
                'rgba(99,102,241,0.72)',
                'rgba(16,185,129,0.78)',
                'rgba(148,163,184,0.70)'
              ],
              borderWidth: 1
            }]
          },
          options:{
            responsive:true,
            maintainAspectRatio:false,
            cutout:'62%',
            plugins:{
              legend:{ position:'left', labels:{ boxWidth:10, font:{ size:9 } } },
              datalabels:{ font:{ size:9, weight:'bold' }, formatter:(v)=> v ? Math.round(v) : '' }
            }
          }
        });
      }

      // Page-3 TOD pie (from provided data)
      const p3pie = document.getElementById('p3TodPie');
      if(p3pie){
        new Chart(p3pie,{
          type:'pie',
          data:{
            labels:[
              'TOD-1 (10 PM से 6 AM)',
              'TOD-2 (6 AM से 9 AM)',
              'TOD-3 (9 AM से 5 PM)',
              'TOD-4 (5 PM से 10 PM)'
            ],
            datasets:[{
              data:[437.25,469.50,120.12,456.75],
              backgroundColor:[
                'rgba(31,111,178,0.85)',
                'rgba(245,158,11,0.80)',
                'rgba(16,185,129,0.78)',
                'rgba(99,102,241,0.72)'
              ],
              borderWidth: 1
            }]
          },
          options:{
            responsive:true,
            maintainAspectRatio:false,
            plugins:{
              legend:{ position:'bottom', labels:{ boxWidth:10, font:{ size:9 } } },
              datalabels:{ font:{ size:9, weight:'bold' }, formatter:(v)=> v.toFixed(0) }
            }
          }
        });
      }

      // Page-3 Meter reading trends (from provided data)
      const rt = document.getElementById('p3ReadingTrend');
      if(rt){
        new Chart(rt, {
          type:'bar',
          data:{
            labels:['अप्रै','जून','अग','अक्टू','दिसं','फर'],
            datasets:[{
              label:'खपत (kWh)',
              data:[149,140,127,127,135,130],
              backgroundColor:'rgba(31,111,178,0.85)',
              borderRadius:6
            }]
          },
          options:{
            responsive:true,
            maintainAspectRatio:false,
            plugins:{
              legend:{ display:true },
              datalabels:{ anchor:'end', align:'end', offset:-2, font:{ size:9, weight:'bold' } }
            },
            scales:{ x:{ grid:{ display:false } }, y:{ beginAtZero:true } }
          }
        });
      }

    });
</script>

</body>
</html>
